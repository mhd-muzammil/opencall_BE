# Copy to backend/.env for local pnpm development.
NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://opencall:opencall@localhost:5432/opencall
JWT_ACCESS_SECRET=dev-jwt-secret-change-me
UPLOAD_DIR=./storage/uploads
CORS_ORIGIN=http://localhost:3000
ADMIN_COOKIE_SECRET=dev-admin-cookie-secret-change-me
ADMIN_SESSION_SECRET=dev-admin-session-secret-change-me

# --- Inventory HP Stock sync (cases with a part are pushed into the Inventory app) ---
# LOCAL DEV (default): write directly to the Inventory SQLite file.
INVENTORY_DB_PATH=/absolute/path/to/inventory_web/inventory_backend/db.sqlite3
# PRODUCTION: push via the Inventory HTTP API instead. When INVENTORY_API_URL is set,
# the API path is used and INVENTORY_DB_PATH is ignored. The API user must be an
# admin/super_admin/manager so the sync can look up cases across all regions.
# INVENTORY_API_URL=https://inventoryback.systimus.in/api
# INVENTORY_API_USER=svc-opencall
# INVENTORY_API_PASSWORD=change-me
