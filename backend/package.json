{
  "name": "@opencall/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "db:check": "tsx src/scripts/checkDatabase.ts",
    "migrate:user-management": "tsx src/scripts/applyUserManagementMigration.ts",
    "migrate:activity-log": "tsx src/scripts/applyActivityLogMigration.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "user:upsert-admin": "node dist/scripts/upsertAdminUser.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@adminjs/express": "^6.1.1",
    "@adminjs/sql": "^2.2.6",
    "@babel/plugin-syntax-import-assertions": "7.28.6",
    "@opencall/shared": "workspace:*",
    "@tiptap/core": "2.27.2",
    "@tiptap/extension-horizontal-rule": "2.27.2",
    "@tiptap/pm": "2.27.2",
    "adminjs": "^7.8.17",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
