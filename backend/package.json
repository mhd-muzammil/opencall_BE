{
  "name": "@opencall/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "db:check": "tsx src/scripts/checkDatabase.ts",
    "migrate:user-management": "tsx src/scripts/applyUserManagementMigration.ts",
    "migrate:activity-log": "tsx src/scripts/applyActivityLogMigration.ts",
    "migrate:required-regions": "tsx src/scripts/applyRequiredRegionSeedMigration.ts",
    "migrate:engineers": "tsx src/scripts/applyEngineersMigration.ts",
    "migrate:rtpl-statuses": "tsx src/scripts/applyRtplStatusesMigration.ts",
    "migrate:status-aging": "tsx src/scripts/applyStatusAgingMigration.ts",
    "migrate:flex-status-days": "tsx src/scripts/applyFlexStatusUnchangedDaysMigration.ts",
    "migrate:evening-status": "tsx src/scripts/applyEveningStatusMigration.ts",
    "migrate:record-layouts": "tsx src/scripts/applyRecordLayoutsMigration.ts",
    "migrate:special-access": "tsx src/scripts/applySpecialAccessMigration.ts",
    "migrate:warranty": "tsx src/scripts/applyWarrantyMigration.ts",
    "migrate:same-day-closed": "tsx src/scripts/applySameDayClosedMigration.ts",
    "migrate:user-regions": "tsx src/scripts/applyUserRegionsMigration.ts",
    "migrate:special-access-edit": "tsx src/scripts/applySpecialAccessEditMigration.ts",
    "pincodes:import": "tsx src/scripts/importPincodeAreaMappings.ts",
    "migrate:user-sections": "tsx src/scripts/applyUserSectionsMigration.ts",
    "migrate:closure-dates": "tsx src/scripts/applyCaseClosureDatesMigration.ts",
    "migrate:customer-feedback": "tsx src/scripts/applyCustomerFeedbackMigration.ts",
    "migrate:customer-feedback-v2": "tsx src/scripts/applyCustomerFeedbackStructuredMigration.ts",
    "migrate:parts-catalog": "tsx src/scripts/applyPartsCatalogMigration.ts",
    "migrate:quotations": "tsx src/scripts/applyQuotationsMigration.ts",
    "migrate:region-eod": "tsx src/scripts/applyRegionEodMigration.ts",
    "migrate:engineer-ids": "tsx src/scripts/applyEngineerHpVendorIdsMigration.ts",
    "warranty:worker": "tsx src/worker/warrantyWorker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "user:upsert-admin": "node dist/scripts/upsertAdminUser.js",
    "hp-stock:backfill": "node dist/scripts/backfillHpStockSync.js",
    "hp-stock:sync-counts": "tsx src/scripts/syncPartsCallCounts.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@adminjs/express": "^6.1.1",
    "@adminjs/sql": "^2.2.6",
    "@babel/plugin-syntax-import-assertions": "7.28.6",
    "@opencall/shared": "workspace:*",
    "@tiptap/core": "2.27.2",
    "@tiptap/extension-horizontal-rule": "2.27.2",
    "@tiptap/pm": "2.27.2",
    "adminjs": "^7.8.17",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "playwright": "1.49.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
